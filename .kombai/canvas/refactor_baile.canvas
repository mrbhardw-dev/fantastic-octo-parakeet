      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .broadsheet-bg {\n    background-color: oklch(0.99 0.004 145); /* var(--background) */\n    position: relative;\n    overflow: hidden;\n  }\n\n  .broadsheet-bg::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background-image: url('https://images.unsplash.com/photo-1637325258040-d2f09636ecf6?auto=format&w=1440&q=80&fit=crop');\n    background-size: cover;\n    opacity: 0.05;\n    pointer-events: none;\n    mix-blend-mode: multiply;\n  }\n\n  .grid-container {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));\n    border: 0.5px solid oklch(0.91 0.02 145); /* var(--border) */\n  }\n\n  .grid-item {\n    border: 0.5px solid oklch(0.91 0.02 145); /* var(--border) */\n  }\n</style>\n\n<div class=\"broadsheet-bg min-h-screen text-foreground font-sans selection:bg-primary/20 p-4 sm:p-12\" data-kid=\"1\">\n  <div class=\"relative mx-auto max-w-7xl\" data-kid=\"2\">\n    \n    \n    <header class=\"border-b-2 border-foreground pb-8 mb-12\" data-kid=\"3\">\n      <div class=\"flex flex-col md:flex-row justify-between items-start md:items-end gap-6\" data-kid=\"4\">\n        <div class=\"border border-foreground p-6 bg-white/40 backdrop-blur-md\" data-kid=\"5\">\n           <div class=\"flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-primary mb-2 font-bold\" data-kid=\"6\">\n             <i class=\"ti ti-map-pin\" data-kid=\"7\"></i> Kilcock, Co. Kildare\n           </div>\n           <div class=\"flex items-center gap-4\" data-kid=\"8\">\n             <i class=\"ti ti-cloud-storm text-primary text-3xl\" data-kid=\"9\"></i>\n             <div data-kid=\"10\">\n               <p class=\"text-sm font-mono font-bold leading-none\" data-kid=\"11\">14°C</p>\n               <p class=\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground mt-1\" data-kid=\"12\">Light Rain</p>\n             </div>\n           </div>\n        </div>\n        \n        <div class=\"text-right flex-1 md:block\" data-kid=\"13\">\n           <div class=\"text-[10px] font-mono uppercase tracking-[0.4em] text-muted-foreground border-b border-border pb-1 mb-1\" data-kid=\"14\">Official Local Ledger</div>\n           <p class=\"text-[10px] font-mono uppercase tracking-[0.4em] text-foreground font-bold\" data-kid=\"15\">Vol. 1 · No. 042 · SATURDAY, JUNE 13, 2026</p>\n        </div>\n      </div>\n      \n      <div class=\"mt-12 flex flex-col md:flex-row justify-between items-end gap-6\" data-kid=\"16\">\n        <div class=\"max-w-2xl\" data-kid=\"17\">\n          <h1 class=\"text-7xl sm:text-9xl font-bold tracking-tighter leading-[0.85] uppercase\" data-kid=\"18\">\n            Local <span class=\"text-primary\" data-kid=\"19\">Feed</span>\n          </h1>\n          <p class=\"mt-4 text-sm font-mono uppercase tracking-widest text-muted-foreground\" data-kid=\"20\">\n            The community noticeboard & daily record of events in Kilcock\n          </p>\n        </div>\n        <button class=\"bg-primary text-primary-foreground px-8 py-4 font-bold uppercase tracking-[0.2em] text-xs hover:bg-primary/90 transition-all hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-primary/20\" data-kid=\"21\">\n          + Post an Update\n        </button>\n      </div>\n    </header>\n\n    \n    <nav class=\"border-y border-foreground py-4 mb-16 flex flex-col md:flex-row items-center gap-6\" data-kid=\"22\">\n      <span class=\"text-[10px] font-mono uppercase tracking-[0.3em] text-primary font-bold whitespace-nowrap bg-primary/10 px-3 py-1\" data-kid=\"23\">Section Index</span>\n      <div class=\"flex flex-wrap justify-center md:justify-start gap-x-8 gap-y-2\" data-kid=\"24\">\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-widest font-bold border-b-2 border-primary pb-1\" data-kid=\"25\">00. Front Page</a>\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-widest text-muted-foreground hover:text-foreground transition-colors pb-1 border-b-2 border-transparent hover:border-border\" data-kid=\"26\">01. Alerts</a>\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-widest text-muted-foreground hover:text-foreground transition-colors pb-1 border-b-2 border-transparent hover:border-border\" data-kid=\"27\">02. Recommendations</a>\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-widest text-muted-foreground hover:text-foreground transition-colors pb-1 border-b-2 border-transparent hover:border-border\" data-kid=\"28\">03. Town Events</a>\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-widest text-muted-foreground hover:text-foreground transition-colors pb-1 border-b-2 border-transparent hover:border-border\" data-kid=\"29\">04. Local Business</a>\n        <a href=\"#\" class=\"text-xs font-mono uppercase tracking-widest text-muted-foreground hover:text-foreground transition-colors pb-1 border-b-2 border-transparent hover:border-border\" data-kid=\"30\">05. Community Q&A</a>\n      </div>\n    </nav>\n\n    \n    <div class=\"grid-container bg-white/20\" data-kid=\"31\">\n       \n       <div class=\"grid-item p-10 hover:bg-white/60 transition-all duration-300 group cursor-pointer border-r border-b border-border\" data-kid=\"32\">\n         <div class=\"flex justify-between items-center mb-8\" data-kid=\"33\">\n           <span class=\"text-[9px] font-mono font-bold uppercase tracking-[0.2em] px-3 py-1 bg-primary text-primary-foreground\" data-kid=\"34\">Alert</span>\n           <span class=\"text-[9px] font-mono text-muted-foreground uppercase tracking-widest\" data-kid=\"35\">14:20 · 13 JUN</span>\n         </div>\n         <h2 class=\"text-3xl font-bold leading-[1.1] mb-6 group-hover:text-primary transition-colors tracking-tight\" data-kid=\"36\">Traffic diversions on Main St due to resurfacing works</h2>\n         <p class=\"text-sm text-muted-foreground line-clamp-4 leading-relaxed mb-8\" data-kid=\"37\">Works are expected to last for three days starting Monday. Access for local residents only between 9am and 5pm. Please follow the posted signage and expect delays during peak hours.</p>\n         <div class=\"flex items-center gap-3 mt-auto pt-6 border-t border-border/40\" data-kid=\"38\">\n           <div class=\"h-1.5 w-1.5 rounded-full bg-primary animate-pulse\" data-kid=\"39\"></div>\n           <span class=\"text-[10px] font-mono uppercase tracking-[0.2em] font-bold group-hover:translate-x-1 transition-transform\" data-kid=\"40\">Read full record →</span>\n         </div>\n       </div>\n\n       \n       <div class=\"grid-item p-10 hover:bg-white/60 transition-all duration-300 group cursor-pointer border-r border-b border-border\" data-kid=\"41\">\n         <div class=\"flex justify-between items-center mb-8\" data-kid=\"42\">\n           <span class=\"text-[9px] font-mono font-bold uppercase tracking-[0.2em] px-3 py-1 bg-accent text-accent-foreground\" data-kid=\"43\">Rec</span>\n           <span class=\"text-[9px] font-mono text-muted-foreground uppercase tracking-widest\" data-kid=\"44\">09:45 · 12 JUN</span>\n         </div>\n         <h2 class=\"text-3xl font-bold leading-[1.1] mb-6 group-hover:text-primary transition-colors tracking-tight\" data-kid=\"45\">Best coffee in Kilcock? Hands down the new bakery by the canal</h2>\n         <p class=\"text-sm text-muted-foreground line-clamp-4 leading-relaxed mb-8\" data-kid=\"46\">Tried the sourdough and the flat white this morning. Incredible quality and the staff are so friendly. Highly recommend supporting them as they get started!</p>\n         <div class=\"flex items-center gap-3 mt-auto pt-6 border-t border-border/40\" data-kid=\"47\">\n           <div class=\"h-1.5 w-1.5 rounded-full bg-accent\" data-kid=\"48\"></div>\n           <span class=\"text-[10px] font-mono uppercase tracking-[0.2em] font-bold group-hover:translate-x-1 transition-transform\" data-kid=\"49\">Read full record →</span>\n         </div>\n       </div>\n\n       \n       <div class=\"grid-item p-10 hover:bg-white/60 transition-all duration-300 group cursor-pointer border-b border-border\" data-kid=\"50\">\n         <div class=\"flex justify-between items-center mb-8\" data-kid=\"51\">\n           <span class=\"text-[9px] font-mono font-bold uppercase tracking-[0.2em] px-3 py-1 bg-purple-600 text-white\" data-kid=\"52\">Event</span>\n           <span class=\"text-[9px] font-mono text-muted-foreground uppercase tracking-widest\" data-kid=\"53\">Yesterday · 18:00</span>\n         </div>\n         <h2 class=\"text-3xl font-bold leading-[1.1] mb-6 group-hover:text-primary transition-colors tracking-tight\" data-kid=\"54\">Summer Market in the Square returns this Saturday</h2>\n         <p class=\"text-sm text-muted-foreground line-clamp-4 leading-relaxed mb-8\" data-kid=\"55\">Join us for local crafts, artisanal food stalls, and live acoustic music. A great day out for all the family. Stalls open from 10am until 6pm in the central plaza.</p>\n         <div class=\"flex items-center gap-3 mt-auto pt-6 border-t border-border/40\" data-kid=\"56\">\n           <div class=\"h-1.5 w-1.5 rounded-full bg-purple-600\" data-kid=\"57\"></div>\n           <span class=\"text-[10px] font-mono uppercase tracking-[0.2em] font-bold group-hover:translate-x-1 transition-transform\" data-kid=\"58\">Read full record →</span>\n         </div>\n       </div>\n\n       \n       <div class=\"grid-item p-10 hover:bg-white/60 transition-all duration-300 group cursor-pointer border-r border-border\" data-kid=\"59\">\n         <div class=\"flex justify-between items-center mb-8\" data-kid=\"60\">\n           <span class=\"text-[9px] font-mono font-bold uppercase tracking-[0.2em] px-3 py-1 bg-blue-600 text-white\" data-kid=\"61\">Business</span>\n           <span class=\"text-[9px] font-mono text-muted-foreground uppercase tracking-widest\" data-kid=\"62\">2 Days Ago</span>\n         </div>\n         <h2 class=\"text-3xl font-bold leading-[1.1] mb-6 group-hover:text-primary transition-colors tracking-tight\" data-kid=\"63\">Local plumber available for emergency callouts and repairs</h2>\n         <p class=\"text-sm text-muted-foreground line-clamp-4 leading-relaxed mb-8\" data-kid=\"64\">Fully certified and insured local tradesman. Covering Kilcock and surrounding areas. No job too small. Contact me for a free quote on residential or commercial work.</p>\n         <div class=\"flex items-center gap-3 mt-auto pt-6 border-t border-border/40\" data-kid=\"65\">\n           <div class=\"h-1.5 w-1.5 rounded-full bg-blue-600\" data-kid=\"66\"></div>\n           <span class=\"text-[10px] font-mono uppercase tracking-[0.2em] font-bold group-hover:translate-x-1 transition-transform\" data-kid=\"67\">Read full record →</span>\n         </div>\n       </div>\n\n       \n       <div class=\"grid-item p-10 hover:bg-white/60 transition-all duration-300 group cursor-pointer border-r border-border\" data-kid=\"68\">\n         <div class=\"flex justify-between items-center mb-8\" data-kid=\"69\">\n           <span class=\"text-[9px] font-mono font-bold uppercase tracking-[0.2em] px-3 py-1 bg-muted text-muted-foreground\" data-kid=\"70\">Misc</span>\n           <span class=\"text-[9px] font-mono text-muted-foreground uppercase tracking-widest\" data-kid=\"71\">3 Days Ago</span>\n         </div>\n         <h2 class=\"text-3xl font-bold leading-[1.1] mb-6 group-hover:text-primary transition-colors tracking-tight\" data-kid=\"72\">Missing silver keys found near the canal heritage path</h2>\n         <p class=\"text-sm text-muted-foreground line-clamp-4 leading-relaxed mb-8\" data-kid=\"73\">Found a set of three keys on a distinctive green keychain. Left them with the staff at the nearby lock café for safekeeping. Hope they find their owner!</p>\n         <div class=\"flex items-center gap-3 mt-auto pt-6 border-t border-border/40\" data-kid=\"74\">\n           <div class=\"h-1.5 w-1.5 rounded-full bg-muted-foreground\" data-kid=\"75\"></div>\n           <span class=\"text-[10px] font-mono uppercase tracking-[0.2em] font-bold group-hover:translate-x-1 transition-transform\" data-kid=\"76\">Read full record →</span>\n         </div>\n       </div>\n\n       \n       <div class=\"grid-item p-10 hover:bg-white/60 transition-all duration-300 group cursor-pointer border-border\" data-kid=\"77\">\n         <div class=\"flex justify-between items-center mb-8\" data-kid=\"78\">\n           <span class=\"text-[9px] font-mono font-bold uppercase tracking-[0.2em] px-3 py-1 bg-primary/20 text-primary\" data-kid=\"79\">Q&A</span>\n           <span class=\"text-[9px] font-mono text-muted-foreground uppercase tracking-widest\" data-kid=\"80\">4 Days Ago</span>\n         </div>\n         <h2 class=\"text-3xl font-bold leading-[1.1] mb-6 group-hover:text-primary transition-colors tracking-tight\" data-kid=\"81\">Anyone have recommendations for a local window cleaner?</h2>\n         <p class=\"text-sm text-muted-foreground line-clamp-4 leading-relaxed mb-8\" data-kid=\"82\">Looking for someone reliable and reasonably priced to clean the exterior windows of a two-story terraced house. Please share your local contacts below!</p>\n         <div class=\"flex items-center gap-3 mt-auto pt-6 border-t border-border/40\" data-kid=\"83\">\n           <div class=\"h-1.5 w-1.5 rounded-full bg-primary/40\" data-kid=\"84\"></div>\n           <span class=\"text-[10px] font-mono uppercase tracking-[0.2em] font-bold group-hover:translate-x-1 transition-transform\" data-kid=\"85\">Read full record →</span>\n         </div>\n       </div>\n    </div>\n\n    \n    <div class=\"mt-16 flex justify-between items-center border-t border-foreground pt-8\" data-kid=\"86\">\n      <div class=\"flex gap-4\" data-kid=\"87\">\n        <button class=\"border border-foreground p-3 hover:bg-primary hover:text-primary-foreground transition-all\" data-kid=\"88\">\n          <i class=\"ti ti-chevron-left text-xl\" data-kid=\"89\"></i>\n        </button>\n        <button class=\"border border-foreground p-3 hover:bg-primary hover:text-primary-foreground transition-all\" data-kid=\"90\">\n          <i class=\"ti ti-chevron-right text-xl\" data-kid=\"91\"></i>\n        </button>\n      </div>\n      <p class=\"text-[10px] font-mono uppercase tracking-[0.4em] text-muted-foreground\" data-kid=\"92\">End of Page 1 · Kilcock Local Ledger</p>\n    </div>\n\n    \n    <footer class=\"mt-32 pt-16 pb-24 border-t-8 border-primary\" data-kid=\"93\">\n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-16\" data-kid=\"94\">\n        <div class=\"col-span-1 md:col-span-2\" data-kid=\"95\">\n          <p class=\"text-5xl font-black uppercase tracking-tighter mb-6 leading-none\" data-kid=\"96\">BAILE.FYI</p>\n          <p class=\"text-sm leading-relaxed text-muted-foreground max-w-md\" data-kid=\"97\">\n            Kilcock's community noticeboard. A digital ledger for residents, businesses, and clubs to share what matters on their doorstep. Built for the community, by the community.\n          </p>\n        </div>\n        <div data-kid=\"98\">\n          <h3 class=\"font-mono text-[10px] uppercase tracking-[0.3em] text-primary mb-8 font-bold\" data-kid=\"99\">Directories</h3>\n          <ul class=\"text-xs font-mono space-y-4 uppercase tracking-widest\" data-kid=\"100\">\n            <li data-kid=\"101\"><a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"102\">/Local-Feed</a></li>\n            <li data-kid=\"103\"><a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"104\">/Town-Events</a></li>\n            <li data-kid=\"105\"><a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"106\">/Directory</a></li>\n            <li data-kid=\"107\"><a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"108\">/Neighbour-Help</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"109\">\n          <h3 class=\"font-mono text-[10px] uppercase tracking-[0.3em] text-primary mb-8 font-bold\" data-kid=\"110\">Contact</h3>\n          <ul class=\"text-xs font-mono space-y-4 uppercase tracking-widest\" data-kid=\"111\">\n            <li data-kid=\"112\"><a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"113\">Twitter</a></li>\n            <li data-kid=\"114\"><a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"115\">Instagram</a></li>\n            <li data-kid=\"116\"><a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"117\">Privacy</a></li>\n            <li data-kid=\"118\"><a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"119\">Moderation</a></li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"mt-20 pt-8 border-t border-border flex justify-between items-center\" data-kid=\"120\">\n        <p class=\"text-[9px] font-mono text-muted-foreground uppercase tracking-[0.3em]\" data-kid=\"121\">© 2026 BAILE.FYI · KILCOCK, CO. KILDARE, IRELAND</p>\n        <div class=\"flex gap-2\" data-kid=\"122\">\n           <div class=\"h-2 w-2 rounded-full bg-primary\" data-kid=\"123\"></div>\n           <div class=\"h-2 w-2 rounded-full bg-accent\" data-kid=\"124\"></div>\n           <div class=\"h-2 w-2 rounded-full bg-white border border-border\" data-kid=\"125\"></div>\n        </div>\n      </div>\n    </footer>\n  </div>\n</div>",
