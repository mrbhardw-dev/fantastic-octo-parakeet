      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800;900&family=Geist+Mono:wght@400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --primary: oklch(0.476 0.163 145);\n    --primary-foreground: oklch(0.99 0 0);\n    --secondary: oklch(0.94 0.03 145);\n    --background: oklch(0.99 0.004 145);\n    --foreground: oklch(0.13 0.01 260);\n    --border: oklch(0.91 0.02 145);\n    --accent: oklch(0.77 0.153 66);\n    --muted-foreground: oklch(0.52 0.02 145);\n  }\n\n  body {\n    background-color: var(--background);\n    color: var(--foreground);\n    font-family: 'Geist', sans-serif;\n    margin: 0;\n  }\n\n  .font-mono { font-family: 'Geist Mono', monospace; }\n  \n  .brutalist-shadow {\n    box-shadow: 4px 4px 0px 0px var(--foreground);\n  }\n\n  @keyframes pulse {\n    0%, 100% { opacity: 1; transform: scale(1); }\n    50% { opacity: 0.5; transform: scale(1.1); }\n  }\n  .animate-pulse-live {\n    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n  }\n\n  .timeline-axis::before {\n    content: '';\n    position: absolute;\n    left: 20%;\n    top: 0;\n    bottom: 0;\n    width: 2px;\n    background-color: var(--primary);\n    transform: translateX(-50%);\n  }\n</style>\n\n<div class=\"min-h-screen\" data-kid=\"1\">\n  \n  <header class=\"border-b border-foreground pt-20 pb-12 px-8\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row md:items-end justify-between gap-8\" data-kid=\"3\">\n      <div data-kid=\"4\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"5\">\n          <div class=\"relative flex items-center justify-center\" data-kid=\"6\">\n            <div class=\"absolute inset-0 bg-red-500/20 rounded-full animate-pulse-live w-6 h-6\" data-kid=\"7\"></div>\n            <i class=\"ti ti-broadcast text-red-600 text-xl relative\" data-kid=\"8\"></i>\n          </div>\n          <span class=\"font-mono text-[10px] tracking-[0.3em] uppercase text-red-600 font-bold\" data-kid=\"9\">Live Activity Feed</span>\n        </div>\n        <h1 class=\"text-7xl md:text-9xl font-black tracking-tighter leading-none\" data-kid=\"10\">\n          LOCAL<br data-kid=\"11\">FEED<span class=\"text-[var(--primary)]\" data-kid=\"12\">.</span>\n        </h1>\n      </div>\n      \n      <div class=\"flex flex-col items-start md:items-end text-left md:text-right max-w-sm\" data-kid=\"13\">\n        <p class=\"font-mono text-[11px] tracking-[0.2em] uppercase text-muted-foreground mb-4\" data-kid=\"14\">\n          KILCOCK / CO. KILDARE / IRELAND\n        </p>\n        <p class=\"text-lg font-medium leading-tight mb-6\" data-kid=\"15\">\n          Community-sourced updates, alerts, and recommendations from your doorstep.\n        </p>\n        <button class=\"bg-[var(--primary)] text-white px-8 py-4 font-bold brutalist-shadow hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all flex items-center gap-3\" data-kid=\"16\">\n          <i class=\"ti ti-plus\" data-kid=\"17\"></i> NEW UPDATE\n        </button>\n      </div>\n    </div>\n  </header>\n\n  \n  <nav class=\"bg-foreground text-background py-6 px-8 sticky top-0 z-50\" data-kid=\"18\">\n    <div class=\"max-w-7xl mx-auto overflow-x-auto\" data-kid=\"19\">\n      <div class=\"flex items-center gap-6 min-w-max\" data-kid=\"20\">\n        <div class=\"pr-6 border-r border-background/20\" data-kid=\"21\">\n          <p class=\"font-mono text-[9px] tracking-widest uppercase opacity-50 mb-1\" data-kid=\"22\">Total.Items</p>\n          <p class=\"text-2xl font-bold font-mono\" data-kid=\"23\">152</p>\n        </div>\n        \n        <div class=\"flex gap-2\" data-kid=\"24\">\n          <button class=\"bg-[var(--primary)] text-white px-4 py-2 font-mono text-xs font-bold uppercase tracking-widest\" data-kid=\"25\">\n            CAT.ALL\n          </button>\n          <button class=\"border border-background/20 hover:bg-background/10 px-4 py-2 font-mono text-xs uppercase tracking-widest transition-colors\" data-kid=\"26\">\n            CAT.ALERT\n          </button>\n          <button class=\"border border-background/20 hover:bg-background/10 px-4 py-2 font-mono text-xs uppercase tracking-widest transition-colors\" data-kid=\"27\">\n            CAT.RECOMMEND\n          </button>\n          <button class=\"border border-background/20 hover:bg-background/10 px-4 py-2 font-mono text-xs uppercase tracking-widest transition-colors\" data-kid=\"28\">\n            CAT.EVENT\n          </button>\n          <button class=\"border border-background/20 hover:bg-background/10 px-4 py-2 font-mono text-xs uppercase tracking-widest transition-colors\" data-kid=\"29\">\n            CAT.BUSINESS\n          </button>\n          <button class=\"border border-background/20 hover:bg-background/10 px-4 py-2 font-mono text-xs uppercase tracking-widest transition-colors\" data-kid=\"30\">\n            CAT.HELP\n          </button>\n        </div>\n      </div>\n    </div>\n  </nav>\n\n  \n  <main class=\"max-w-7xl mx-auto px-8 py-20 relative timeline-axis\" data-kid=\"31\">\n    \n    \n    <div class=\"flex items-start mb-24 group\" data-kid=\"32\">\n      <div class=\"w-1/5 pr-12 text-right\" data-kid=\"33\">\n        <p class=\"font-mono text-4xl font-black text-[var(--primary)] leading-none mb-2\" data-kid=\"34\">05M</p>\n        <p class=\"font-mono text-[10px] tracking-widest uppercase text-muted-foreground\" data-kid=\"35\">Minutes Ago</p>\n        <div class=\"mt-4 flex justify-end\" data-kid=\"36\">\n          <span class=\"bg-red-600 text-white font-mono text-[9px] font-bold px-2 py-1 uppercase tracking-tighter\" data-kid=\"37\">ALERT</span>\n        </div>\n      </div>\n      \n      <div class=\"w-4/5 pl-12\" data-kid=\"38\">\n        <h2 class=\"text-4xl font-extrabold tracking-tight mb-4 group-hover:text-[var(--primary)] transition-colors\" data-kid=\"39\">\n          Emergency roadworks on Bridge Street\n        </h2>\n        <p class=\"text-xl text-muted-foreground leading-relaxed max-w-2xl mb-6\" data-kid=\"40\">\n          Essential repairs starting tonight at 9PM. Expect delays and temporary diversions through the Square. Access for residents maintained.\n        </p>\n        <div class=\"flex items-center gap-6\" data-kid=\"41\">\n          <div class=\"flex items-center gap-2\" data-kid=\"42\">\n            <div class=\"w-8 h-8 rounded-full bg-slate-200\" data-kid=\"43\"></div>\n            <span class=\"font-mono text-xs uppercase font-bold\" data-kid=\"44\">Liam Murphy</span>\n          </div>\n          <button class=\"text-sm font-bold underline underline-offset-4 decoration-2 decoration-[var(--primary)]\" data-kid=\"45\">VIEW DETAILS</button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"flex items-start mb-24 group\" data-kid=\"46\">\n      <div class=\"w-1/5 pr-12 text-right\" data-kid=\"47\">\n        <p class=\"font-mono text-4xl font-black text-foreground leading-none mb-2\" data-kid=\"48\">02H</p>\n        <p class=\"font-mono text-[10px] tracking-widest uppercase text-muted-foreground\" data-kid=\"49\">Hours Ago</p>\n        <div class=\"mt-4 flex justify-end\" data-kid=\"50\">\n          <span class=\"bg-blue-600 text-white font-mono text-[9px] font-bold px-2 py-1 uppercase tracking-tighter\" data-kid=\"51\">RECOMMENDATION</span>\n        </div>\n      </div>\n      \n      <div class=\"w-4/5 pl-12\" data-kid=\"52\">\n        <h2 class=\"text-4xl font-extrabold tracking-tight mb-4 group-hover:text-[var(--primary)] transition-colors\" data-kid=\"53\">\n          Best coffee at The Blackroom\n        </h2>\n        <p class=\"text-xl text-muted-foreground leading-relaxed max-w-2xl mb-6\" data-kid=\"54\">\n          Just tried the new seasonal roast. Unbelievable quality and the staff are always so welcoming. A true local gem we need to support!\n        </p>\n        <div class=\"flex items-center gap-6\" data-kid=\"55\">\n          <div class=\"flex items-center gap-2\" data-kid=\"56\">\n            <div class=\"w-8 h-8 rounded-full bg-slate-200\" data-kid=\"57\"></div>\n            <span class=\"font-mono text-xs uppercase font-bold\" data-kid=\"58\">Sarah Byrne</span>\n          </div>\n          <button class=\"text-sm font-bold underline underline-offset-4 decoration-2 decoration-[var(--primary)]\" data-kid=\"59\">VIEW DETAILS</button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"flex items-start mb-24 group\" data-kid=\"60\">\n      <div class=\"w-1/5 pr-12 text-right\" data-kid=\"61\">\n        <p class=\"font-mono text-4xl font-black text-foreground leading-none mb-2\" data-kid=\"62\">04H</p>\n        <p class=\"font-mono text-[10px] tracking-widest uppercase text-muted-foreground\" data-kid=\"63\">Hours Ago</p>\n        <div class=\"mt-4 flex justify-end\" data-kid=\"64\">\n          <span class=\"bg-amber-600 text-white font-mono text-[9px] font-bold px-2 py-1 uppercase tracking-tighter\" data-kid=\"65\">LOST & FOUND</span>\n        </div>\n      </div>\n      \n      <div class=\"w-4/5 pl-12\" data-kid=\"66\">\n        <h2 class=\"text-4xl font-extrabold tracking-tight mb-4 group-hover:text-[var(--primary)] transition-colors\" data-kid=\"67\">\n          Missing keys near Royal Canal\n        </h2>\n        <p class=\"text-xl text-muted-foreground leading-relaxed max-w-2xl mb-6\" data-kid=\"68\">\n          Set of three keys on a green shamrock keychain. Lost somewhere between the harbour and the train station around 4PM today.\n        </p>\n        <div class=\"flex items-center gap-6\" data-kid=\"69\">\n          <div class=\"flex items-center gap-2\" data-kid=\"70\">\n            <div class=\"w-8 h-8 rounded-full bg-slate-200\" data-kid=\"71\"></div>\n            <span class=\"font-mono text-xs uppercase font-bold\" data-kid=\"72\">Pat O'Connor</span>\n          </div>\n          <button class=\"text-sm font-bold underline underline-offset-4 decoration-2 decoration-[var(--primary)]\" data-kid=\"73\">VIEW DETAILS</button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"flex items-start mb-24 group\" data-kid=\"74\">\n      <div class=\"w-1/5 pr-12 text-right\" data-kid=\"75\">\n        <p class=\"font-mono text-4xl font-black text-foreground leading-none mb-2\" data-kid=\"76\">01D</p>\n        <p class=\"font-mono text-[10px] tracking-widest uppercase text-muted-foreground\" data-kid=\"77\">Days Ago</p>\n        <div class=\"mt-4 flex justify-end\" data-kid=\"78\">\n          <span class=\"bg-purple-600 text-white font-mono text-[9px] font-bold px-2 py-1 uppercase tracking-tighter\" data-kid=\"79\">EVENT</span>\n        </div>\n      </div>\n      \n      <div class=\"w-4/5 pl-12\" data-kid=\"80\">\n        <h2 class=\"text-4xl font-extrabold tracking-tight mb-4 group-hover:text-[var(--primary)] transition-colors\" data-kid=\"81\">\n          Kilcock Summer Fair this Saturday\n        </h2>\n        <p class=\"text-xl text-muted-foreground leading-relaxed max-w-2xl mb-6\" data-kid=\"82\">\n          Join us for the annual community fair! Live music, local food stalls, and games for kids. All proceeds go to the local youth club.\n        </p>\n        <div class=\"flex items-center gap-6\" data-kid=\"83\">\n          <div class=\"flex items-center gap-2\" data-kid=\"84\">\n            <div class=\"w-8 h-8 rounded-full bg-slate-200\" data-kid=\"85\"></div>\n            <span class=\"font-mono text-xs uppercase font-bold\" data-kid=\"86\">Community Board</span>\n          </div>\n          <button class=\"text-sm font-bold underline underline-offset-4 decoration-2 decoration-[var(--primary)]\" data-kid=\"87\">VIEW DETAILS</button>\n        </div>\n      </div>\n    </div>\n\n  </main>\n\n  \n  <footer class=\"bg-foreground text-background py-20 px-8\" data-kid=\"88\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between gap-12\" data-kid=\"89\">\n      <div data-kid=\"90\">\n        <h3 class=\"text-4xl font-black tracking-tighter mb-6 uppercase\" data-kid=\"91\">BAILE<span class=\"text-[var(--primary)]\" data-kid=\"92\">.</span>FYI</h3>\n        <p class=\"font-mono text-[11px] tracking-widest opacity-50 uppercase\" data-kid=\"93\">The community hub for Kilcock</p>\n      </div>\n      <div class=\"grid grid-cols-2 md:grid-cols-3 gap-12\" data-kid=\"94\">\n        <div data-kid=\"95\">\n          <p class=\"font-mono text-[10px] uppercase font-bold tracking-widest mb-6 opacity-30\" data-kid=\"96\">Sections</p>\n          <ul class=\"space-y-3 font-bold text-sm\" data-kid=\"97\">\n            <li data-kid=\"98\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"99\">Local Feed</a></li>\n            <li data-kid=\"100\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"101\">Events</a></li>\n            <li data-kid=\"102\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"103\">Directory</a></li>\n            <li data-kid=\"104\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"105\">Help</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"106\">\n          <p class=\"font-mono text-[10px] uppercase font-bold tracking-widest mb-6 opacity-30\" data-kid=\"107\">Legal</p>\n          <ul class=\"space-y-3 font-bold text-sm\" data-kid=\"108\">\n            <li data-kid=\"109\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"110\">Privacy</a></li>\n            <li data-kid=\"111\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"112\">Terms</a></li>\n            <li data-kid=\"113\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"114\">Safety</a></li>\n          </ul>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>",
