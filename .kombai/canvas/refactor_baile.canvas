      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --primary: oklch(0.476 0.163 145);\n    --primary-foreground: oklch(0.99 0 0);\n    --secondary: oklch(0.94 0.03 145);\n    --secondary-foreground: oklch(0.28 0.07 145);\n    --accent: oklch(0.77 0.153 66);\n    --background: oklch(0.99 0.004 145);\n    --foreground: oklch(0.13 0.01 260);\n    --border: oklch(0.91 0.02 145);\n    --muted-foreground: oklch(0.52 0.02 145);\n  }\n\n  .font-sans { font-family: 'Geist', sans-serif; }\n  .font-mono { font-family: 'Geist Mono', monospace; }\n\n  .broadsheet-grid {\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    border-left: 1px solid var(--border);\n    border-right: 1px solid var(--border);\n  }\n\n  .paper-texture {\n    background-image: url('https://images.unsplash.com/photo-1637325258040-d2f09636ecf6?auto=format&w=1440&q=80&fit=crop');\n    background-blend-mode: multiply;\n  }\n</style>\n\n<div class=\"font-sans text-[var(--foreground)] bg-[var(--background)] paper-texture bg-fixed min-h-screen\" data-kid=\"1\">\n  \n  <div class=\"max-w-7xl mx-auto border-x border-[var(--border)]\" data-kid=\"2\">\n    <div class=\"flex items-center justify-between px-8 py-4 border-b border-[var(--border)]\" data-kid=\"3\">\n      <div class=\"flex items-center gap-4\" data-kid=\"4\">\n        <div class=\"font-mono text-xs uppercase tracking-widest text-[var(--primary)] font-bold\" data-kid=\"5\">Volume 01 / Issue 12</div>\n        <div class=\"h-4 w-px bg-[var(--border)]\" data-kid=\"6\"></div>\n        <div class=\"font-mono text-xs uppercase tracking-widest text-[var(--muted-foreground)]\" data-kid=\"7\">June 13, 2026</div>\n      </div>\n      <div class=\"flex items-center gap-6 font-mono text-xs uppercase font-medium\" data-kid=\"8\">\n        <div class=\"flex items-center gap-2\" data-kid=\"9\">\n          <i class=\"ti ti-map-pin text-[var(--primary)]\" data-kid=\"10\"></i>\n          <span data-kid=\"11\">Kilcock, Co. Kildare</span>\n        </div>\n        <div class=\"flex items-center gap-2\" data-kid=\"12\">\n          <i class=\"ti ti-cloud-sun text-[var(--primary)]\" data-kid=\"13\"></i>\n          <span data-kid=\"14\">18°C · Partly Cloudy</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-[40%_1fr] border-b border-[var(--border)]\" data-kid=\"15\">\n      \n      <div class=\"p-8 lg:p-12 border-r border-[var(--border)] flex flex-col justify-between\" data-kid=\"16\">\n        <div data-kid=\"17\">\n          <p class=\"font-mono text-[10px] text-[var(--primary)] font-bold tracking-[0.3em] uppercase mb-8\" data-kid=\"18\">\n            baile /bal-uh/ · Irish for home, place & belonging\n          </p>\n          <h1 class=\"text-6xl lg:text-7xl font-bold tracking-tighter leading-[0.9] mb-10\" data-kid=\"19\">\n            Your home town.<br data-kid=\"20\">\n            <span class=\"text-[var(--primary)] italic\" data-kid=\"21\">Your home page.</span>\n          </h1>\n          <p class=\"text-lg text-[var(--muted-foreground)] leading-relaxed max-w-sm mb-12\" data-kid=\"22\">\n            The community noticeboard for Kilcock — a shared digital ledger for residents, businesses, and neighbours.\n          </p>\n        </div>\n        \n        <div class=\"flex flex-col gap-3\" data-kid=\"23\">\n          <button class=\"w-full bg-[var(--primary)] text-[var(--primary-foreground)] py-4 font-bold uppercase tracking-widest text-sm hover:opacity-90 transition-opacity\" data-kid=\"24\">\n            Browse local feed\n          </button>\n          <div class=\"grid grid-cols-2 gap-3\" data-kid=\"25\">\n            <button class=\"border border-[var(--border)] py-4 font-bold uppercase tracking-widest text-xs hover:bg-[var(--secondary)] transition-colors\" data-kid=\"26\">\n              Post update\n            </button>\n            <button class=\"border border-[var(--border)] py-4 font-bold uppercase tracking-widest text-xs hover:bg-[var(--secondary)] transition-colors\" data-kid=\"27\">\n              See events\n            </button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"p-8 lg:p-12 bg-[var(--secondary)]/30\" data-kid=\"28\">\n        <div class=\"flex items-center justify-between mb-8\" data-kid=\"29\">\n          <h2 class=\"font-mono text-xs font-bold uppercase tracking-[0.2em]\" data-kid=\"30\">Latest Classifieds</h2>\n          <i class=\"ti ti-asterisk text-[var(--primary)]\" data-kid=\"31\"></i>\n        </div>\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"32\">\n          \n          <div class=\"md:col-span-2 border border-[var(--border)] bg-[var(--background)] p-6 group cursor-pointer hover:border-[var(--primary)] transition-colors\" data-kid=\"33\">\n            <div class=\"flex items-center justify-between mb-4\" data-kid=\"34\">\n              <span class=\"font-mono text-[10px] font-bold uppercase px-2 py-0.5 border border-[var(--primary)] text-[var(--primary)]\" data-kid=\"35\">Alert</span>\n              <span class=\"font-mono text-[10px] text-[var(--muted-foreground)] uppercase\" data-kid=\"36\">2 hours ago</span>\n            </div>\n            <h3 class=\"text-2xl font-bold leading-tight mb-3 group-hover:underline underline-offset-4 decoration-[var(--primary)]\" data-kid=\"37\">Water main repair scheduled for Church Street this Tuesday.</h3>\n            <p class=\"text-sm text-[var(--muted-foreground)] line-clamp-2 leading-relaxed\" data-kid=\"38\">Local authorities have announced essential maintenance works starting at 9 AM. Residents are advised to store water...</p>\n          </div>\n          \n          \n          <div class=\"border border-[var(--border)] bg-[var(--background)] p-6 group cursor-pointer hover:border-[var(--primary)] transition-colors\" data-kid=\"39\">\n            <div class=\"flex items-center justify-between mb-4\" data-kid=\"40\">\n              <span class=\"font-mono text-[10px] font-bold uppercase px-2 py-0.5 border border-[var(--accent)] text-[var(--accent)]\" data-kid=\"41\">Lost & Found</span>\n              <span class=\"font-mono text-[10px] text-[var(--muted-foreground)] uppercase\" data-kid=\"42\">5 hours ago</span>\n            </div>\n            <h3 class=\"text-lg font-bold leading-tight mb-2 group-hover:text-[var(--primary)] transition-colors\" data-kid=\"43\">Black Labrador found near the Royal Canal.</h3>\n            <p class=\"text-xs text-[var(--muted-foreground)] line-clamp-2 leading-relaxed\" data-kid=\"44\">Very friendly, no collar. Currently being looked after at the Harbour Inn.</p>\n          </div>\n\n          \n          <div class=\"border border-[var(--border)] bg-[var(--background)] p-6 group cursor-pointer hover:border-[var(--primary)] transition-colors\" data-kid=\"45\">\n            <div class=\"flex items-center justify-between mb-4\" data-kid=\"46\">\n              <span class=\"font-mono text-[10px] font-bold uppercase px-2 py-0.5 border border-blue-400 text-blue-600\" data-kid=\"47\">Recommendation</span>\n              <span class=\"font-mono text-[10px] text-[var(--muted-foreground)] uppercase\" data-kid=\"48\">Yesterday</span>\n            </div>\n            <h3 class=\"text-lg font-bold leading-tight mb-2 group-hover:text-[var(--primary)] transition-colors\" data-kid=\"49\">Best coffee in town? Try the new bakery on the square.</h3>\n            <p class=\"text-xs text-[var(--muted-foreground)] line-clamp-2 leading-relaxed\" data-kid=\"50\">The sourdough is incredible and the staff are so welcoming. A great addition to Kilcock.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"border-b border-[var(--border)] overflow-hidden\" data-kid=\"51\">\n      <div class=\"flex whitespace-nowrap py-4 animate-marquee hover:pause items-center\" data-kid=\"52\">\n        <div class=\"flex items-center shrink-0\" data-kid=\"53\">\n          <span class=\"font-mono text-3xl font-bold px-12 uppercase tracking-tighter\" data-kid=\"54\">\n            <span class=\"text-[var(--primary)]\" data-kid=\"55\">1,248</span> Posts\n          </span>\n          <i class=\"ti ti-asterisk text-[var(--border)] scale-150\" data-kid=\"56\"></i>\n          <span class=\"font-mono text-3xl font-bold px-12 uppercase tracking-tighter\" data-kid=\"57\">\n            <span class=\"text-purple-600\" data-kid=\"58\">24</span> Events\n          </span>\n          <i class=\"ti ti-asterisk text-[var(--border)] scale-150\" data-kid=\"59\"></i>\n          <span class=\"font-mono text-3xl font-bold px-12 uppercase tracking-tighter\" data-kid=\"60\">\n            <span class=\"text-blue-600\" data-kid=\"61\">156</span> Businesses\n          </span>\n          <i class=\"ti ti-asterisk text-[var(--border)] scale-150\" data-kid=\"62\"></i>\n          <span class=\"font-mono text-3xl font-bold px-12 uppercase tracking-tighter\" data-kid=\"63\">\n            <span class=\"text-amber-600\" data-kid=\"64\">89</span> Neighbours Helped\n          </span>\n          <i class=\"ti ti-asterisk text-[var(--border)] scale-150\" data-kid=\"65\"></i>\n        </div>\n        \n        <div class=\"flex items-center shrink-0\" data-kid=\"66\">\n          <span class=\"font-mono text-3xl font-bold px-12 uppercase tracking-tighter\" data-kid=\"67\">\n            <span class=\"text-[var(--primary)]\" data-kid=\"68\">1,248</span> Posts\n          </span>\n          <i class=\"ti ti-asterisk text-[var(--border)] scale-150\" data-kid=\"69\"></i>\n          <span class=\"font-mono text-3xl font-bold px-12 uppercase tracking-tighter\" data-kid=\"70\">\n            <span class=\"text-purple-600\" data-kid=\"71\">24</span> Events\n          </span>\n          <i class=\"ti ti-asterisk text-[var(--border)] scale-150\" data-kid=\"72\"></i>\n          <span class=\"font-mono text-3xl font-bold px-12 uppercase tracking-tighter\" data-kid=\"73\">\n            <span class=\"text-blue-600\" data-kid=\"74\">156</span> Businesses\n          </span>\n          <i class=\"ti ti-asterisk text-[var(--border)] scale-150\" data-kid=\"75\"></i>\n          <span class=\"font-mono text-3xl font-bold px-12 uppercase tracking-tighter\" data-kid=\"76\">\n            <span class=\"text-amber-600\" data-kid=\"77\">89</span> Neighbours Helped\n          </span>\n          <i class=\"ti ti-asterisk text-[var(--border)] scale-150\" data-kid=\"78\"></i>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"p-8 lg:p-12 border-b border-[var(--border)]\" data-kid=\"79\">\n      <div class=\"flex items-end justify-between mb-12\" data-kid=\"80\">\n        <div data-kid=\"81\">\n          <h2 class=\"text-4xl font-bold tracking-tight\" data-kid=\"82\">The Community Ledger</h2>\n          <p class=\"font-mono text-xs text-[var(--muted-foreground)] uppercase mt-2\" data-kid=\"83\">Continuous updates from your doorstep</p>\n        </div>\n        <button class=\"font-mono text-xs font-bold uppercase tracking-widest border-b-2 border-[var(--primary)] pb-1 hover:text-[var(--primary)] transition-colors\" data-kid=\"84\">\n          View all entries\n        </button>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-t border-l border-[var(--border)]\" data-kid=\"85\">\n        \n        <div class=\"border-r border-b border-[var(--border)] p-8 hover:bg-[var(--secondary)]/20 transition-colors cursor-pointer group\" data-kid=\"86\">\n          <div class=\"flex items-center gap-2 mb-6\" data-kid=\"87\">\n            <div class=\"w-2 h-2 rounded-full bg-green-500\" data-kid=\"88\"></div>\n            <span class=\"font-mono text-[10px] font-bold uppercase tracking-widest\" data-kid=\"89\">Community Help · 10m ago</span>\n          </div>\n          <h3 class=\"text-xl font-bold mb-4 leading-tight group-hover:text-[var(--primary)]\" data-kid=\"90\">Elderly neighbour needs help with garden clearing this Saturday.</h3>\n          <p class=\"text-sm text-[var(--muted-foreground)] leading-relaxed\" data-kid=\"91\">A resident on O'Connell Square is looking for two volunteers to help with some light pruning and waste removal...</p>\n        </div>\n\n        \n        <div class=\"border-r border-b border-[var(--border)] p-8 hover:bg-[var(--secondary)]/20 transition-colors cursor-pointer group\" data-kid=\"92\">\n          <div class=\"flex items-center gap-2 mb-6\" data-kid=\"93\">\n            <div class=\"w-2 h-2 rounded-full bg-purple-500\" data-kid=\"94\"></div>\n            <span class=\"font-mono text-[10px] font-bold uppercase tracking-widest\" data-kid=\"95\">Event · 45m ago</span>\n          </div>\n          <h3 class=\"text-xl font-bold mb-4 leading-tight group-hover:text-[var(--primary)]\" data-kid=\"96\">Farmer's Market returning to the square this weekend.</h3>\n          <p class=\"text-sm text-[var(--muted-foreground)] leading-relaxed\" data-kid=\"97\">Expect fresh local produce, artisan crafts, and live music from 10 AM to 4 PM. Support your local growers!</p>\n        </div>\n\n        \n        <div class=\"border-r border-b border-[var(--border)] p-8 hover:bg-[var(--secondary)]/20 transition-colors cursor-pointer group\" data-kid=\"98\">\n          <div class=\"flex items-center gap-2 mb-6\" data-kid=\"99\">\n            <div class=\"w-2 h-2 rounded-full bg-blue-500\" data-kid=\"100\"></div>\n            <span class=\"font-mono text-[10px] font-bold uppercase tracking-widest\" data-kid=\"101\">Local Business · 2h ago</span>\n          </div>\n          <h3 class=\"text-xl font-bold mb-4 leading-tight group-hover:text-[var(--primary)]\" data-kid=\"102\">New yoga studio opening doors on Mill Street.</h3>\n          <p class=\"text-sm text-[var(--muted-foreground)] leading-relaxed\" data-kid=\"103\">Introductory classes starting next Monday. All levels welcome, from beginners to advanced practitioners.</p>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 border-b border-[var(--border)]\" data-kid=\"104\">\n      <div class=\"p-10 border-r border-[var(--border)] group hover:bg-[var(--secondary)] transition-colors cursor-pointer\" data-kid=\"105\">\n        <div class=\"w-12 h-12 flex items-center justify-center border border-[var(--primary)] text-[var(--primary)] mb-8 transition-transform group-hover:scale-110\" data-kid=\"106\">\n          <i class=\"ti ti-news text-2xl\" data-kid=\"107\"></i>\n        </div>\n        <h3 class=\"text-xl font-bold mb-4 uppercase tracking-tighter\" data-kid=\"108\">Local Feed</h3>\n        <p class=\"text-sm text-[var(--muted-foreground)] leading-relaxed mb-6\" data-kid=\"109\">Alerts, news, and recommendations from your neighbours.</p>\n        <div class=\"font-mono text-[10px] font-bold uppercase flex items-center gap-2 text-[var(--primary)]\" data-kid=\"110\">\n          Open Index <i class=\"ti ti-arrow-right\" data-kid=\"111\"></i>\n        </div>\n      </div>\n\n      <div class=\"p-10 border-r border-[var(--border)] group hover:bg-[var(--secondary)] transition-colors cursor-pointer\" data-kid=\"112\">\n        <div class=\"w-12 h-12 flex items-center justify-center border border-purple-500 text-purple-600 mb-8 transition-transform group-hover:scale-110\" data-kid=\"113\">\n          <i class=\"ti ti-calendar-event text-2xl\" data-kid=\"114\"></i>\n        </div>\n        <h3 class=\"text-xl font-bold mb-4 uppercase tracking-tighter\" data-kid=\"115\">Events</h3>\n        <p class=\"text-sm text-[var(--muted-foreground)] leading-relaxed mb-6\" data-kid=\"116\">Never miss what's happening in and around Kilcock.</p>\n        <div class=\"font-mono text-[10px] font-bold uppercase flex items-center gap-2 text-purple-600\" data-kid=\"117\">\n          Open Index <i class=\"ti ti-arrow-right\" data-kid=\"118\"></i>\n        </div>\n      </div>\n\n      <div class=\"p-10 border-r border-[var(--border)] group hover:bg-[var(--secondary)] transition-colors cursor-pointer\" data-kid=\"119\">\n        <div class=\"w-12 h-12 flex items-center justify-center border border-blue-500 text-blue-600 mb-8 transition-transform group-hover:scale-110\" data-kid=\"120\">\n          <i class=\"ti ti-building-store text-2xl\" data-kid=\"121\"></i>\n        </div>\n        <h3 class=\"text-xl font-bold mb-4 uppercase tracking-tighter\" data-kid=\"122\">Directory</h3>\n        <p class=\"text-sm text-[var(--muted-foreground)] leading-relaxed mb-6\" data-kid=\"123\">Support the businesses that keep our town thriving.</p>\n        <div class=\"font-mono text-[10px] font-bold uppercase flex items-center gap-2 text-blue-600\" data-kid=\"124\">\n          Open Index <i class=\"ti ti-arrow-right\" data-kid=\"125\"></i>\n        </div>\n      </div>\n\n      <div class=\"p-10 group hover:bg-[var(--secondary)] transition-colors cursor-pointer\" data-kid=\"126\">\n        <div class=\"w-12 h-12 flex items-center justify-center border border-amber-500 text-amber-600 mb-8 transition-transform group-hover:scale-110\" data-kid=\"127\">\n          <i class=\"ti ti-heart-handshake text-2xl\" data-kid=\"128\"></i>\n        </div>\n        <h3 class=\"text-xl font-bold mb-4 uppercase tracking-tighter\" data-kid=\"129\">Help</h3>\n        <p class=\"text-sm text-[var(--muted-foreground)] leading-relaxed mb-6\" data-kid=\"130\">A helping hand is always nearby. Ask or offer support.</p>\n        <div class=\"font-mono text-[10px] font-bold uppercase flex items-center gap-2 text-amber-600\" data-kid=\"131\">\n          Open Index <i class=\"ti ti-arrow-right\" data-kid=\"132\"></i>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"bg-[var(--primary)] text-[var(--primary-foreground)] p-12 lg:p-20 relative overflow-hidden\" data-kid=\"133\">\n      \n      <i class=\"ti ti-shield-check absolute -bottom-10 -left-10 text-white/5 text-[240px] pointer-events-none\" data-kid=\"134\"></i>\n      <i class=\"ti ti-users absolute -top-10 -right-10 text-white/5 text-[240px] pointer-events-none\" data-kid=\"135\"></i>\n\n      <div class=\"relative z-10 max-w-4xl mx-auto text-center\" data-kid=\"136\">\n        <p class=\"font-mono text-xs font-bold uppercase tracking-[0.4em] mb-6 opacity-60\" data-kid=\"137\">tar abhaile · come home</p>\n        <h2 class=\"text-5xl lg:text-7xl font-bold tracking-tighter leading-none mb-8\" data-kid=\"138\">\n          A place for residents,<br data-kid=\"139\">by residents.\n        </h2>\n        <p class=\"text-xl opacity-90 max-w-2xl mx-auto leading-relaxed mb-12\" data-kid=\"140\">\n          Join the community to post updates, add events, and connect with your neighbours. No ads, no tracking—just Kilcock.\n        </p>\n        <div class=\"flex flex-wrap justify-center gap-4\" data-kid=\"141\">\n          <button class=\"bg-white text-[var(--primary)] px-10 py-5 font-bold uppercase tracking-widest text-sm hover:bg-opacity-90 transition-all\" data-kid=\"142\">\n            Create free account\n          </button>\n          <button class=\"border-2 border-white/30 text-white px-10 py-5 font-bold uppercase tracking-widest text-sm hover:bg-white/10 transition-all\" data-kid=\"143\">\n            Browse feed first\n          </button>\n        </div>\n      </div>\n      \n      \n      <div class=\"max-w-6xl mx-auto mt-24 pt-12 border-t border-white/10 grid grid-cols-1 md:grid-cols-3 gap-12 relative z-10\" data-kid=\"144\">\n        <div class=\"flex flex-col items-center text-center\" data-kid=\"145\">\n          <i class=\"ti ti-shield-check text-2xl mb-4\" data-kid=\"146\"></i>\n          <h4 class=\"font-bold uppercase tracking-widest text-xs mb-2\" data-kid=\"147\">Moderated Content</h4>\n          <p class=\"text-xs opacity-60\" data-kid=\"148\">Every post is reviewed for safety.</p>\n        </div>\n        <div class=\"flex flex-col items-center text-center\" data-kid=\"149\">\n          <i class=\"ti ti-map-pin text-2xl mb-4\" data-kid=\"150\"></i>\n          <h4 class=\"font-bold uppercase tracking-widest text-xs mb-2\" data-kid=\"151\">Built for Kilcock</h4>\n          <p class=\"text-xs opacity-60\" data-kid=\"152\">Specific to our town's needs.</p>\n        </div>\n        <div class=\"flex flex-col items-center text-center\" data-kid=\"153\">\n          <i class=\"ti ti-users text-2xl mb-4\" data-kid=\"154\"></i>\n          <h4 class=\"font-bold uppercase tracking-widest text-xs mb-2\" data-kid=\"155\">Community Run</h4>\n          <p class=\"text-xs opacity-60\" data-kid=\"156\">No commercial tracking or ads.</p>\n        </div>\n      </div>\n    </section>\n  </div>\n</div>\n\n<style data-kid=\"157\">\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .animate-marquee {\n    display: flex;\n    width: max-content;\n    animation: marquee 40s linear infinite;\n  }\n  .pause:hover {\n    animation-play-state: paused;\n  }\n</style>",
